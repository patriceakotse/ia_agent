# Application
APP_NAME=Agent Orchestrator
DEBUG=true
SECRET_KEY=change-this-secret-key-in-production-min-32-chars

# Database
# SQLite for local dev (no Docker)
DATABASE_URL=sqlite:///./agent_orchestrator.db

# Or PostgreSQL for Docker
# DATABASE_URL=postgresql://postgres:postgres@db:5432/agent_orchestrator

# Security
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Providers (at least one required)
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
XAI_API_KEY=your-xai-api-key-here
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7

# xAI (Grok) Settings
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.3

# OpenHands Integration
OPENHANDS_URL=http://localhost:3000
OPENHANDS_API_KEY=local-dev

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]